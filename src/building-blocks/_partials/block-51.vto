---
block: block-51
---

{{ comp grid.Block { block, internal, draft, id, tag: 'li', classes: 'participants', source: 'Bradford 2025' } }}

	<h3>Volunteers by postcode district</h3>

	{{>
		const {
			people: people,
		} = search.data("themes/volunteers");

		const postcodeSignUps = geojson.postcodes.features.map(x => x.properties.name)
		.map(code => ({ code, count: 0, ...people.by_geo_postcode_area.find(w => w.code == code) }))
		.map(d => ({
			...d,
			count: d.count <= 5 && d.count > 0 ? 5 : d.count,
			countLabel: d.count <= 5 && d.count > 0 ? '5 or fewer' : d.count.toString()
		}) )

		const unknown_address = people.by_geo_TOTAL.find(x => x.type === 'TOTAL' && x.code === 'UNKNOWN').count;
		const total_volunteers = people.by_geo_TOTAL.find(x => x.type === 'TOTAL' && x.code === 'TOTAL').count;
		const known_address = total_volunteers - unknown_address;
	}}

	{{ comp Tab.Set { classes: 'big'} }}
		{{ comp Tab.Panel { id: 'volunteers-pcd-hex', label: 'Cartogram' } }}
			{{ comp.oi.map.hex_cartogram({
				config: {
					hexjson: hexes.bd_pcd_simple,
					data: postcodeSignUps,
					matchKey: 'code',
					value: 'count',
					min: 0,
					max: 400,
					scale: scales.pink,
					label: 'code',
					width: 500,
					legend: {
						continuous: true,
						position: 'top right',
						items: [{'value':400,'label':'>400'},{'value':200,'label':'200'},{'value':0,'label':'0'}]
					},
					tooltip: '{{ code }}\n<strong>{{ count | toLocaleString }}</strong> volunteers',
					tools: {
						filter: {
							label: 'n',
							position: 'top left'
						},
						panzoom: {
							maxZoom: 2,
							scrollWheelZoom: false
						}
					}
				}
			}) }}
			<p>This {{ comp glossary.Ref { slug: 'cartogram' } }}cartogram{{ /comp }} displays postcode districts as equal-sized hexagons. This allows us to more easily compare postcode districts rather than have the impression skewed by the physical area.</p>
			<p class="source">Hex layout: Open Innovations</p>
		{{ /comp }}
		{{ comp Tab.Panel { id: 'volunteers-pcd-map', label: 'Map' } }}
			{{ comp.oi.map.svg({
				config: {
					geojson: {
						key: 'name',
						data: geojson.postcodes
					},
					data: postcodeSignUps,
					columns: [{
						name: "filterLabel",
						template: "{{ geojson.properties.name }}"
					}],
					key: 'code',
					value: 'count',
					min: 0,
					max: 400,
					scale: scales.pink,
					label: 'short_code',
					width: 500,
					legend: {
						continuous: true,
						position: 'top right',
						items: [{'value':400,'label':'>400'},{'value':200,'label':'200'},{'value':0,'label':'0'}]
					},
					tooltip: '{{ filterLabel }}\n<strong>{{ count | toLocaleString }}</strong> volunteers',
					tools: {
						filter: {
							label: 'filterLabel',
							position: 'top left'
						},
						panzoom: {
							maxZoom: 2,
							scrollWheelZoom: false
						}
					}
				}
			}) }}
		{{ /comp }}
	{{ /comp }}
	<p>We have verified address details for {{ Math.round(100 * known_address / total_volunteers) }}% of our volunteers.</p>

{{ /comp }}