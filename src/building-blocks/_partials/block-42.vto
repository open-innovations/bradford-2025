{{ comp grid.Block { block, internal, draft, id, tag: 'li', classes: 'audiences', source: 'Bradford 2025 Audience Survey / <a href="https://www.nomisweb.co.uk/query/select/getdatasetbytheme.asp?theme=28">ONS Annual Labour Force Survey</a> (2025)', notes: 'This uses <a href="https://github.com/open-innovations/bradford-2025/blob/main/src/building-blocks/_data/survey_employment.csv">a static CSV file</a> provided by the Evaluation Team. The audience survey splits unemployed into two different groups but the ALFS does not.' } }}

	<h3>Audience survey demographics: employment</h3>
	
	{{> const { survey_employment } = search.data("building-blocks"); }}
	{{ import { buildBreakdown } from "./functions.vto" }}
