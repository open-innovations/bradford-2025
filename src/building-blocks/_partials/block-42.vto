		"Retired from paid work":"#9e9e9e",
		"Full-time student":"#437e2a",
		"Unemployed":"#e1699f",
		"Not currently employed but have been employed within last 12 months":"#E98EB7",
		"Not been in paid employment for last 12 months":"#F0B4CF",
		"Prefer not to say":"#ffffff",
		"Never worked":"#dddddd"
	}) }}

	<p>Last updated {{ comp.Date({start:'2026-02',dateFormat:'LLLL y'}) }}.</p>

