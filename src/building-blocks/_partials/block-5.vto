---
block: block-5
---

{{ comp grid.Block { block, internal, draft, id, tag: 'li', classes: 'audiences', source: 'Bradford 2025', notes: 'This shows the values where BY_MONTH_BY_EVAL_CAT is "Digital" in <a href="https://github.com/open-innovations/bradford-2025/blob/main/src/_data/published/programme/by_month.csv">by_month.csv</a>.' } }}

	<h3>Digital audience</h3>

	{{>
		const audience = calculated.programme.audience.categories.digital.value;
		const graph = calculated.programme.audience.monthly.categories.digital.filter((r) => r.Date.match(/^2025-/) );
	}}
	{{ comp.BigNumber({
		number: audience || 0,
		classes: 'big',
		animate: true,
		roundingOptions: { maximumFractionDigits: 0 }
	}) }}
	{{ comp.graph.monthly({
		data: graph,
		series: [{
			title: 'Digital',
			x: 'Date',
			y: 'value',
			colour: 'green'
		}]
	}) }}
	<p>The size of the {{ comp glossary.Ref { slug: 'audience' } }}audience{{ /comp }} for digital events. The overall total includes data from {{ comp.Date({start:calculated.programme.audience.dates.earliest, end:calculated.programme.audience.dates.latest}) }}.</p>
{{ /comp }}